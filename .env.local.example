# GymFlow — copy to .env.local (single reception PC)

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Local: http://localhost:3000 | Vercel: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Must match fingerprint-bridge/.env API_KEY
FINGERPRINT_API_KEY=change-me-to-a-long-random-string

# Comma-separated Supabase auth emails that can access the admin system.
# Users with app_metadata.role set to "admin" or "super_admin" are also allowed.
SUPER_ADMIN_EMAILS=admin@gym.com

# Local bridge (single-PC)
FINGERPRINT_BRIDGE_URL=http://localhost:5050

# Attendance date timezone (Pakistan default)
GYM_TIMEZONE=Asia/Karachi
