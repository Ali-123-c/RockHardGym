# Single-PC setup: copy to fingerprint-bridge/.env
# Run GymFlow (npm run dev) and bridge (npm run dev) on the SAME computer.

API_BASE_URL=http://localhost:3000
API_KEY=change-me-to-a-long-random-string

BRIDGE_PORT=5050
RECONNECT_INTERVAL_MS=10000

# After saving device in Admin → Devices, paste the UUID here
DEVICE_ID=your_device_uuid_from_supabase

# ZKTeco IP on your LAN (set static IP on device menu)
DEVICE_IP=192.168.1.100
DEVICE_PORT=4370
DEVICE_PASSWORD=

SYNC_INTERVAL_MINUTES=5
RETRY_INTERVAL_MS=60000

MODE=real
