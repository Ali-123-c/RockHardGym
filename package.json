{
  "name": "gymflow",
  "version": "1.0.0",
  "description": "Simple Gym Management System with Fingerprint Attendance",
  "scripts": {
    "dev": "next dev",
    "dev:bridge": "npm --prefix fingerprint-bridge run dev",
    "start:bridge": "npm --prefix fingerprint-bridge start",
    "build": "next build",
    "build:bridge": "npm --prefix fingerprint-bridge run build",
    "start": "next start",
    "lint": "next lint",
    "test": "node tests/run-tests.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:load": "k6 run tests/load/api-load-test.js",
    "lighthouse": "lhci autorun",
    "sonar": "sonar-scanner"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.56.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.16.0",
    "next": "^15.5.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.0",
    "eslint": "9.39.4",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "typescript": "^6.0.3"
  }
}
